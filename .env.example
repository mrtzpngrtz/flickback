# Database (PostgreSQL)
DATABASE_URL="postgresql://framemark:password@localhost:5432/framemark"

# S3-compatible storage (Hetzner Object Storage or MinIO)
S3_ENDPOINT="https://fsn1.your-objectstorage.com"
S3_REGION="eu-central"
S3_BUCKET="framemark-videos"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"

# Public URL for video playback (CDN or direct bucket URL)
# If bucket is public: S3_PUBLIC_URL = https://your-bucket.fsn1.your-objectstorage.com
# If using presigned URLs: leave empty
S3_PUBLIC_URL=""

# Presigned URL TTL in seconds (default: 3600 = 1 hour)
S3_PRESIGN_TTL="3600"

# App
NEXT_PUBLIC_APP_URL="https://framemark.yourdomain.com"
APP_SECRET="generate-a-long-random-string-here"
